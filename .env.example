# Google Apps Script Web App URL (대시보드 데이터 GET 요청용)
# 빌드/실행 전 .env 파일을 복사한 뒤 값을 채워주세요.
VITE_WEB_APP_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# (선택) Python server/els_samsung_scraper.py
# 기본: ELS/DLS 찾기 → 청약완료상품 탭 → 상단「회차명」검색 후 결과에서 상세 링크
# SAMSUNG_ELS_SEARCH_URL=https://www.samsungpop.com/ux/kor/finance/els/saleGoods/search.do?MENU_ID=
# 사이트 탭 인덱스가 바뀌면 조정 (기본 2 = 청약완료상품)
# SAMSUNG_ELS_COMPLETED_TAB=2
# 직접 상세 URL을 쓸 때만 ({round} 치환 — ISCD URL에는 회차만으로는 부적합)
# SAMSUNG_ELS_DETAIL_URL_TEMPLATE=
# PLAYWRIGHT_NAV_TIMEOUT_MS=45000

# (선택) Python server/els_meritz_scraper.py — 메리츠 청약완료·투자설명서 PDF
# 기본 0: 직링크만(메인·메뉴는 로그인으로 보내지는 경우가 많음). 메뉴가 필요할 때만 1.
# MERITZ_USE_MENU_NAV=0
# MERITZ_HOME_URL=https://home.imeritz.com/index.jsp
# MERITZ_SBSC_CMPT_URL=https://home.imeritz.com/drvtlnkdprod/SbscCmptProd.do
# MERITZ_PLAYWRIGHT_CHANNEL=chrome
# MERITZ_HEADLESS=0
# PLAYWRIGHT_NAV_TIMEOUT_MS=90000
# MERITZ_USE_RAW_API_POST=0

# Google 로그인 (OAuth 2.0 클라이언트 ID · 웹 애플리케이션)
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
